<Window x:Class="TaskManagerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TaskManagerUI.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Менеджер задач" Height="700" Width="1381"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:PriorityToColorConverter x:Key="PriorityToColorConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ModernListView" TargetType="ListView">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="ModernGridViewColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderBrush" Value="#1a1a2e"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0f3460" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🚀 Менеджер задач" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtStats" Text="📊 Всего: 0 | ✅ Завершено: 0 | ⚠️ Просрочено: 0" 
                               FontSize="14" Foreground="#a8d8ea" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#16213e" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="📝 Название:" Foreground="#a8d8ea" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtTitle" Style="{StaticResource ModernTextBox}" Margin="0,0,15,0"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="⚡ Приоритет:" Foreground="#a8d8ea" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                <ComboBox Grid.Row="0" Grid.Column="3" Foreground="#0f3460" x:Name="cmbPriority" Style="{StaticResource ModernComboBox}" Margin="0,0,15,0" SelectedIndex="1">
                    <ComboBoxItem Content="🟢 Низкий"/>
                    <ComboBoxItem Content="🟡 Средний"/>
                    <ComboBoxItem Content="🔴 Высокий"/>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="📌 Статус:" Foreground="#a8d8ea" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                <ComboBox Grid.Row="0" Grid.Column="5" Foreground="#0f3460" x:Name="cmbStatus" Style="{StaticResource ModernComboBox}" Margin="0,0,15,0" SelectedIndex="0">
                    <ComboBoxItem Content="🆕 Новая"/>
                    <ComboBoxItem Content="⏳ В процессе"/>
                    <ComboBoxItem Content="✅ Завершена"/>
                </ComboBox>

                <CheckBox Grid.Row="0" Grid.Column="6" x:Name="chkImportant" Content="⭐ Важная" 
                          Style="{StaticResource ModernCheckBox}" VerticalAlignment="Center"/>

                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="📄 Описание:" Foreground="#a8d8ea" VerticalAlignment="Center" Margin="0,0,10,5" FontSize="13"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDescription" Style="{StaticResource ModernTextBox}" Margin="0,0,15,0"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="📅 Срок:" Foreground="#a8d8ea" VerticalAlignment="Center" Margin="0,0,10,5" FontSize="13"/>
                <DatePicker Grid.Row="1" Grid.Column="3" Foreground="#0f3460" x:Name="dpDeadline" Style="{StaticResource ModernDatePicker}" 
                            Margin="0,0,15,0" SelectedDate="{x:Static sys:DateTime.Now}"/>

              
                <StackPanel Grid.Row="1" Grid.Column="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnAdd" Content="➕ Добавить" Width="130" 
                            Style="{StaticResource ModernButton}" Background="#00b894" Click="BtnAdd_Click"/>
                    <Button x:Name="btnUpdate" Content="✏️ Обновить" Width="130" 
                            Style="{StaticResource ModernButton}" Background="#0984e3" Click="BtnUpdate_Click" IsEnabled="False" Margin="10,0,0,0"/>
                    <Button x:Name="btnClear" Content="🗑️ Очистить" Width="120" 
                            Style="{StaticResource ModernButton}" Background="#fdcb6e" Click="BtnClear_Click" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="10" BorderBrush="#0f3460" BorderThickness="2" Margin="0,0,0,15" Background="#16213e">
            <ListView x:Name="lvTasks" Style="{StaticResource ModernListView}" 
                      BorderThickness="0" SelectionChanged="LvTasks_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="45" DisplayMemberBinding="{Binding Id}">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                        </GridViewColumn>
                        <GridViewColumn Header="📝 Название" Width="150" DisplayMemberBinding="{Binding Title}">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                        </GridViewColumn>
                        <GridViewColumn Header="📄 Описание" Width="200" DisplayMemberBinding="{Binding Description}">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                        </GridViewColumn>
                        <GridViewColumn Header="⚡ Приоритет" Width="100">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,2" 
                                            Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                        <TextBlock Text="{Binding Priority}" Foreground="White" 
                                                   FontWeight="Bold" HorizontalAlignment="Center" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="📌 Статус" Width="110">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,2" 
                                            Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                        <TextBlock Text="{Binding Status}" Foreground="White" 
                                                   FontWeight="Bold" HorizontalAlignment="Center" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="📅 Срок" Width="100" DisplayMemberBinding="{Binding Deadline, StringFormat=dd.MM.yyyy}">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                        </GridViewColumn>
                        <GridViewColumn Header="⭐" Width="50">
                            <GridViewColumn.HeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}"/>
                            </GridViewColumn.HeaderContainerStyle>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="⭐" FontSize="18" 
                                               Visibility="{Binding IsImportant, Converter={StaticResource BoolToVisibilityConverter}}"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Border Grid.Row="3" Background="#16213e" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="txtSearch" Style="{StaticResource ModernTextBox}" 
                         Margin="0,0,10,0" TextChanged="txtSearch_TextChanged"
                         ToolTip="🔍 Поиск по названию или описанию"/>

                <Button Grid.Column="1" Content="📋 Все" Width="75" Style="{StaticResource ModernButton}" 
                        Background="#6c5ce7" Click="BtnFilterAll_Click" Margin="0,0,5,0"/>
                <Button Grid.Column="2" Content="🆕 Новые" Width="85" Style="{StaticResource ModernButton}" 
                        Background="#00b894" Click="BtnFilterNew_Click" Margin="0,0,5,0"/>
                <Button Grid.Column="3" Content="⏳ В процессе" Width="105" Style="{StaticResource ModernButton}" 
                        Background="#fdcb6e" Click="BtnFilterInProgress_Click" Margin="0,0,5,0"/>
                <Button Grid.Column="4" Content="✅ Завершены" Width="105" Style="{StaticResource ModernButton}" 
                        Background="#00b894" Click="BtnFilterCompleted_Click" Margin="0,0,5,0"/>

                <Separator Grid.Column="5" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                           Margin="5,0" Background="#0f3460" Width="2"/>

                <Button Grid.Column="6" Content="⬆ Приоритет" Width="110" Style="{StaticResource ModernButton}" 
                        Background="#0984e3" Click="BtnSortPriority_Click" Margin="0,0,5,0"/>
                <Button Grid.Column="7" Content="📅 Срок" Width="90" Style="{StaticResource ModernButton}" 
                        Background="#0984e3" Click="BtnSortDeadline_Click" Margin="0,0,5,0"/>

                <Button Grid.Column="8" Content="🗑 Удалить" Width="100" Style="{StaticResource ModernButton}" 
                        Background="#e17055" Click="BtnDelete_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>